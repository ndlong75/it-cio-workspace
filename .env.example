# IT CIO Workspace — Environment Variables
# File: .env
# ⚠️  KHÔNG commit file này lên Git — đã có trong .gitignore

# ── ANTHROPIC ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── JIRA ─────────────────────────────────────────────────
JIRA_URL=https://your-company.atlassian.net
JIRA_EMAIL=your_email@company.com
JIRA_TOKEN=your_jira_api_token
JIRA_PROJECT=IT

# ── GITHUB ───────────────────────────────────────────────
GITHUB_TOKEN=ghp_your_github_token
GITHUB_ORG=your-company-github-org

# ── MICROSOFT 365 ────────────────────────────────────────
# (Dùng qua MCP Connector — không cần token ở đây)
M365_TEAMS_CHANNEL_IT=your-teams-channel-id
M365_TEAMS_CHANNEL_CIO=your-cio-channel-id

# ── TELEGRAM (nếu dùng) ──────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_IT=your_it_group_chat_id

# ── MONITORING ───────────────────────────────────────────
MONITORING_API_URL=http://your-monitoring-server/api
MONITORING_API_KEY=your_monitoring_key

# ── CORE SYSTEM ──────────────────────────────────────────
CORE_SYSTEM_URL=http://your-core-system/api
CORE_SYSTEM_KEY=your_core_key
